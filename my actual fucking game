<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Colombo 1492</title>
  </head>
  <body>
    <div id="root"></div>
    <script type="module" src="/main.jsx"></script>
  </body>
</html>
import React from "react";
import ReactDOM from "react-dom/client";
import App from "./App.jsx";

ReactDOM.createRoot(document.getElementById("root")).render(
  <App />
);
import React, { useEffect, useMemo, useRef, useState } from "react";
import { motion } from "framer-motion";
import { Button } from "<button>Start</button>";
import { Card, CardContent } from "<div>...</div>";

type Area = "deck" | "hold" | "quarters";
type Facing = "left" | "right";

type Mission = {
  title: string;
  type: string;
  goal: number;
  hint: string;
};

const WORLD_W = 2200;
const SHIP_MIN_X = 160;
const SHIP_MAX_X = 2000;
const ROOM_MIN_X = 70;
const ROOM_MAX_X = 830;
const DEFAULT_VIEW_W = 1280;
const DEFAULT_VIEW_H = 720;

function clamp(value: number, min: number, max: number) {
  return Math.max(min, Math.min(max, value));
}

function getPlayerY(area: Area) {
  if (area === "deck") return 300; // slight lift so feet don't clip
  if (area === "hold") return 180; // slight lift
  return 180; // quarters
}

function getCamera(playerX: number, area: Area, viewW = DEFAULT_VIEW_W, viewH = DEFAULT_VIEW_H) {
  if (area === "quarters") return { x: 0, y: 0 };
  const x = clamp(playerX - viewW / 2, 0, Math.max(0, WORLD_W - viewW));

  // Deck and hold are now separate side-scrolling maps.
  // The hold should NOT be pushed vertically anymore; it already has its own interior layout.
  // FIX: lower camera so ship is centered properly
  // FIX: move camera DOWN (positive Y) so ship is visible
  return { x, y: 180 };
}

function getObjective(type: string): { x: number; area: Area } {
  const places: Record<string, { x: number; area: Area }> = {
    cargo: { x: 520, area: "hold" },
    cook: { x: 760, area: "hold" },
    song: { x: 1180, area: "deck" },
    map: { x: 1550, area: "deck" },
    diary: { x: 1650, area: "deck" },
    storm: { x: 1120, area: "deck" },
    fish: { x: 1970, area: "deck" },
    sails: { x: 1010, area: "deck" },
    navigate: { x: 1780, area: "deck" },
    final: { x: 2050, area: "deck" },
    sleep: { x: 330, area: "quarters" }
  };
  return places[type] || { x: 1000, area: "deck" };
}

const missionsByDay: Record<number, Mission[]> = {
  1: [
    { title: "Carregar comida", type: "cargo", goal: 6, hint: "Esta missão está temporariamente ignorada no BETA." },
    { title: "Sair do porto", type: "navigate", goal: 5, hint: "Vá até o leme no convés." }
  ],
  2: [
    { title: "Desviar das pedras", type: "navigate", goal: 7, hint: "Três colisões obrigam o conserto do casco." },
    { title: "Preparar ensopado", type: "cook", goal: 4, hint: "Desça ao porão e use o fogão." }
  ],
  3: [
    { title: "Canção marítima", type: "song", goal: 5, hint: "Cante perto dos marinheiros no convés." },
    { title: "Ondas gigantes", type: "navigate", goal: 8, hint: "Use o leme para manter o navio estável." }
  ],
  4: [
    { title: "Ler o mapa", type: "map", goal: 3, hint: "Vá até a mesa de mapas na cabine." },
    { title: "Diário de bordo", type: "diary", goal: 1, hint: "Use a escrivaninha na cabine." }
  ],
  5: [
    { title: "Céu cinza", type: "storm", goal: 6, hint: "Organize os marinheiros correndo no convés." },
    { title: "Pesca", type: "fish", goal: 5, hint: "Vá até a beirada direita do navio." }
  ],
  6: [
    { title: "Reparar velas", type: "sails", goal: 8, hint: "Vá até as cordas do mastro." },
    { title: "Seguir estrelas", type: "map", goal: 4, hint: "Use a mesa de mapas." }
  ],
  7: [
    { title: "Avistar terra", type: "navigate", goal: 10, hint: "Mantenha o navio estável até o fim." },
    { title: "Chegada", type: "final", goal: 1, hint: "Vá até a proa e desembarque." }
  ]
};

export default function Colombo1492Beta() {
  const [screen, setScreen] = useState("home");
  const [day, setDay] = useState(1);
  const [challenge, setChallenge] = useState(0);
  const [crew, setCrew] = useState(12);
  const [hits, setHits] = useState(0);
  const [message, setMessage] = useState("Bem-vindo à BETA da viagem de 1492.");
  const [timer, setTimer] = useState(0);
  const [showHint, setShowHint] = useState(false);
  const [progress, setProgress] = useState(0);
  const [playerX, setPlayerX] = useState(270);
  const [area, setArea] = useState<Area>("deck");
  const [facing, setFacing] = useState<Facing>("right");
  const [mustSleep, setMustSleep] = useState(false);

  const keysRef = useRef({ left: false, right: false });
  const velocityRef = useRef(0);
  const interactLockRef = useRef(false);

  const viewW = typeof window !== "undefined" ? window.innerWidth : DEFAULT_VIEW_W;
  const viewH = typeof window !== "undefined" ? window.innerHeight : DEFAULT_VIEW_H;
  const camera = getCamera(playerX, area, viewW, viewH);

  const curiosities: Record<number, string> = {
    1: "Curiosidade: Colombo partiu de Palos de la Frontera, na Espanha, em 3 de agosto de 1492.",
    2: "Curiosidade: a expedição tinha três embarcações: Niña, Pinta e Santa María.",
    3: "Curiosidade: muitos marinheiros temiam não encontrar terra e ficar sem suprimentos.",
    4: "Curiosidade: Colombo pensava estar chegando às Índias, mas alcançou ilhas do Caribe.",
    5: "Curiosidade: tempestades e desorientação eram riscos constantes nas travessias.",
    6: "Curiosidade: a navegação usava mapas, estrelas, experiência e muita sorte.",
    7: "Curiosidade: a chegada às Américas mudou profundamente a história do mundo."
  };

  const missions = useMemo(() => missionsByDay, []);
  const current = missions[day][challenge];
  const totalMissionsToday = missions[day].length;
  const completedMissionsToday = mustSleep ? totalMissionsToday : challenge;
  const isSunset = completedMissionsToday >= totalMissionsToday / 2 && !mustSleep;
  const objective = mustSleep ? getObjective("sleep") : getObjective(current.type);

  const nearLadder = area !== "quarters" && Math.abs(playerX - 1040) < 70;
  const nearQuartersDoor = area === "hold" && Math.abs(playerX - 330) < 90;
  const nearExitDoor = area === "quarters" && Math.abs(playerX - 90) < 70;
  const nearObjective = Math.abs(playerX - objective.x) < 95 && area === objective.area;

  useEffect(() => {
    if (screen !== "game") return;
    const id = window.setInterval(() => {
      setTimer(t => {
        const next = t + 1;
        if (next > 7) setShowHint(true);
        return next;
      });
    }, 1000);
    return () => window.clearInterval(id);
  }, [screen]);

  useEffect(() => {
    function onKeyDown(e: KeyboardEvent) {
      if (screen !== "game") return;
      const k = e.key.toLowerCase();
      if (k === "arrowleft" || k === "a") {
        keysRef.current.left = true;
        setFacing("left");
      }
      if (k === "arrowright" || k === "d" || k === "w") {
        keysRef.current.right = true;
        setFacing("right");
      }
      if ((k === " " || k === "e") && !interactLockRef.current) {
        interactLockRef.current = true;
        interact();
      }
    }

    function onKeyUp(e: KeyboardEvent) {
      const k = e.key.toLowerCase();
      if (k === "arrowleft" || k === "a") keysRef.current.left = false;
      if (k === "arrowright" || k === "d" || k === "w") keysRef.current.right = false;
      if (k === " " || k === "e") interactLockRef.current = false;
    }

    window.addEventListener("keydown", onKeyDown);
    window.addEventListener("keyup", onKeyUp);
    return () => {
      window.removeEventListener("keydown", onKeyDown);
      window.removeEventListener("keyup", onKeyUp);
    };
  }, [screen, playerX, area, nearLadder, nearQuartersDoor, nearExitDoor, nearObjective, mustSleep, progress, current]);

  useEffect(() => {
    if (screen !== "game") return;
    let frame = 0;

    function tick() {
      const keys = keysRef.current;
      const targetVelocity = keys.left && !keys.right ? -4.2 : keys.right && !keys.left ? 4.2 : 0;
      const acceleration = targetVelocity === 0 ? 0.28 : 0.18;
      velocityRef.current += (targetVelocity - velocityRef.current) * acceleration;
      if (Math.abs(velocityRef.current) < 0.03) velocityRef.current = 0;
      if (velocityRef.current < 0) setFacing("left");
      if (velocityRef.current > 0) setFacing("right");

      const min = area === "quarters" ? ROOM_MIN_X : SHIP_MIN_X;
      const max = area === "quarters" ? ROOM_MAX_X : SHIP_MAX_X;
      setPlayerX(x => clamp(x + velocityRef.current, min, max));
      frame = requestAnimationFrame(tick);
    }

    frame = requestAnimationFrame(tick);
    return () => cancelAnimationFrame(frame);
  }, [screen, area]);

  function resetMission(text = "Nova missão iniciada.") {
    setProgress(0);
    setTimer(0);
    setShowHint(false);
    setMessage(text);
  }

  function startGame() {
    setDay(1);
    setChallenge(0);
    setCrew(12);
    setHits(0);
    setProgress(0);
    setPlayerX(270);
    setArea("deck");
    setMustSleep(false);
    setScreen("game");
    resetMission("Mentor: explore o navio. A escada leva ao porão; a porta do porão leva aos aposentos.");
  }

  function interact() {
    if (area === "deck" && nearLadder) {
      setArea("hold");
      setPlayerX(1040);
      setMessage("Você desceu para o porão.");
      return;
    }
    if (area === "hold" && nearLadder) {
      setArea("deck");
      setPlayerX(1040);
      setMessage("Você subiu para o convés.");
      return;
    }
    if (area === "hold" && nearQuartersDoor) {
      setArea("quarters");
      setPlayerX(120);
      setMessage("Você entrou nos aposentos.");
      return;
    }
    if (area === "quarters" && nearExitDoor) {
      setArea("hold");
      setPlayerX(330);
      setMessage("Você saiu dos aposentos e voltou ao porão.");
      return;
    }
    if (mustSleep) {
      sleepAction();
      return;
    }
    action();
  }

  function loseCrew(amount: number) {
    const next = Math.max(0, crew - amount);
    setCrew(next);
    if (next <= 0) {
      setMessage("Todos os marinheiros foram perdidos. A expedição fracassou.");
      setScreen("gameover");
    }
  }

  function completeMission() {
    if (challenge === 0) {
      setChallenge(1);
      setPlayerX(320);
      setArea("deck");
      resetMission("Mentor: boa. Agora complete o segundo desafio do dia antes de dormir.");
    } else {
      setMustSleep(true);
      setPlayerX(980);
      setArea("deck");
      resetMission("Mentor: o dia acabou. Desça ao porão, entre nos aposentos e durma.");
    }
  }

  function sleepAction() {
    if (!nearObjective) {
      setMessage("A cama fica nos aposentos. Entre pela porta no porão e siga até a cama.");
      return;
    }
    setMustSleep(false);
    setScreen("sleep");
    setMessage(curiosities[day]);
  }

  function nextDay() {
    if (day >= 7) {
      setScreen("victory");
      return;
    }
    setDay(day + 1);
    setChallenge(0);
    setHits(0);
    setPlayerX(320);
    setArea("deck");
    setMustSleep(false);
    setScreen("game");
    resetMission(`Mentor: Dia ${day + 1}. A travessia fica mais difícil.`);
  }

  function action() {
    if (current.type === "cargo") {
      setMessage("Missão de caixas ignorada por enquanto no BETA.");
      setProgress(current.goal);
      setTimeout(completeMission, 350);
      return;
    }
    if (!nearObjective) {
      setMessage(objective.area === "hold" ? "A missão está no porão." : "Siga até o objetivo correto para interagir.");
      return;
    }
    if (current.type === "diary" || current.type === "final") {
      setProgress(1);
      setMessage(current.type === "diary" ? "Diário escrito. A tripulação se acalmou." : "Terra à vista. A travessia foi concluída.");
      setTimeout(completeMission, 600);
      return;
    }
    const next = progress + 1;
    setProgress(next);
    setMessage(`Progresso: ${next}/${current.goal}`);
    if (next >= current.goal) setTimeout(completeMission, 600);
  }

  function collision() {
    const newHits = hits + 1;
    setHits(newHits);
    if (newHits >= 3) {
      setScreen("repair");
      setMessage("O casco foi danificado! Conserte antes que o navio afunde.");
    } else {
      loseCrew(2);
      setMessage("Colisão! Dois marinheiros foram perdidos.");
    }
  }

  function repairSuccess() {
    setHits(0);
    setProgress(0);
    setScreen("game");
    resetMission("Casco reparado. Continue a missão.");
  }

  if (screen === "home") {
    return <FullCenter><Card className="w-full max-w-3xl bg-slate-900 border-slate-700 shadow-2xl rounded-2xl"><CardContent className="p-8 text-center space-y-6"><h1 className="text-4xl font-black tracking-tight">1492: Travessia de Colombo</h1><p className="text-slate-300">BETA 2D lateral — convés, porão e aposentos separados.</p><div className="flex flex-wrap gap-3 justify-center"><Button onClick={startGame}>Start</Button><Button variant="secondary" onClick={() => setScreen("tutorial")}>Tutorial</Button><Button variant="outline" onClick={() => setScreen("credits")}>Créditos</Button></div></CardContent></Card></FullCenter>;
  }

  if (screen === "tutorial") return <Panel title="Tutorial"><p>Use ← → ou A/D para andar. Segure W para andar para frente. Use Espaço ou E para interagir.</p><p>Escada: convés ↔ porão. Porta no porão: aposentos.</p><Button onClick={startGame}>Começar</Button><Button variant="outline" onClick={() => setScreen("home")}>Voltar</Button></Panel>;
  if (screen === "credits") return <Panel title="Créditos"><p>Protótipo educacional inspirado na viagem atlântica de 1492.</p><Button onClick={() => setScreen("home")}>Voltar</Button></Panel>;
  if (screen === "repair") return <Panel title="Consertar o casco"><p>{message}</p><p>Clique três vezes para reparar as tábuas.</p><Button onClick={() => setProgress(p => p + 1)}>Martelar tábua</Button><p>Reparo: {progress}/3</p>{progress >= 3 && <Button onClick={repairSuccess}>Voltar ao mar</Button>}</Panel>;
  if (screen === "sleep") return <Panel title={`Fim do Dia ${day}`}><p>{message}</p><p>Colombo dorme. A tripulação recupera forças.</p><Button onClick={nextDay}>{day >= 7 ? "Ver final" : "Próximo dia"}</Button></Panel>;
  if (screen === "gameover") return <Panel title="Derrota"><p>{message}</p><Button onClick={startGame}>Tentar novamente</Button></Panel>;
  if (screen === "victory") return <Panel title="Vitória"><p>Você completou a BETA da travessia de 1492.</p><p>Tripulação restante: {crew}</p><Button onClick={() => setScreen("home")}>Menu</Button></Panel>;

  return <div className="fixed inset-0 bg-black text-white overflow-hidden select-none">
    <style>{css}</style>
    <div className="hud-minimal"><span>Dia {day}</span><span>Missão {challenge + 1}/2: {mustSleep ? "Dormir" : current.title}</span><span>Marinheiros: {crew}</span></div>
    {area === "quarters" ? <QuartersScene playerX={playerX} facing={facing} nearExitDoor={nearExitDoor} mustSleep={mustSleep} nearBed={nearObjective} /> : area === "hold" ? <HoldScene camera={camera} playerX={playerX} facing={facing} nearLadder={nearLadder} nearQuartersDoor={nearQuartersDoor} crew={crew} /> : <ShipScene camera={camera} isSunset={isSunset} mustSleep={mustSleep} nearLadder={nearLadder} playerX={playerX} facing={facing} crew={crew} currentType={current.type} collision={collision} action={action} />}
    {showHint && <div className="hint-box">Dica: {mustSleep ? "Entre nos aposentos e durma." : current.hint}</div>}
  </div>;
}

function ShipScene({ camera, isSunset, mustSleep, nearLadder, playerX, facing, crew, currentType, collision, action }: any) {
  return <div className={`game-world ${isSunset ? "sunset" : ""} ${mustSleep ? "night" : ""}`}>
    <div className="cloud c1" /><div className="cloud c2" /><div className="sun" /><div className="far-water" /><div className="water waveA" /><div className="water waveB" /><div className="water waveC" /><div className="water waveD" />
    <div className="world-scroll" style={{ transform: `translate(${-camera.x}px, ${-camera.y}px)` }}><div className="ship-big"><div className="mast mast1" /><div className="mast mast2" /><div className="deck-floor" /><div className="rail" /><div className="captain-cabin" /><div className="lower-hull" /><div className="hull-planks" /><div className="portholes" /><div className="ladder" /><div className="ladder-label" style={{ opacity: nearLadder ? 1 : 0 }}>Interaja para descer</div>{Array.from({ length: Math.min(crew, 12) }).map((_, i) => <Npc key={i} i={i} area="deck" />)}<Player x={playerX} area="deck" facing={facing} /></div>{!mustSleep && (currentType === "navigate" || currentType === "storm") && <><button className="rock r1" onClick={collision} aria-label="rocha" /><button className="rock r2" onClick={collision} aria-label="rocha" /><button className="rock r3" onClick={collision} aria-label="rocha" /></>}{!mustSleep && currentType === "fish" && <><button className="fish f1" onClick={action} aria-label="peixe" /><button className="fish f2" onClick={action} aria-label="peixe" /><button className="fish f3" onClick={action} aria-label="peixe" /></>}</div>
  </div>;
}

function HoldScene({ camera, playerX, facing, nearLadder, nearQuartersDoor, crew }: any) {
  return <div className="hold-map">
    <div className="hold-scroll" style={{ transform: `translateX(${-camera.x}px)` }}>
      <div className="hold-hull-shell" />
      <div className="hold-ribs" />
      <div className="hold-floor" />
      <div className="hold-beam-top" />
      {/* FIX: replace door with real ladder */}
      <div className="hold-ladder" />
      <div className="hold-ladder-label" style={{ opacity: nearLadder ? 1 : 0 }}>Interaja para subir</div>
      <div className="hold-quarters-entrance" />
      <div className="hold-quarters-label" style={{ opacity: nearQuartersDoor ? 1 : 0 }}>Interaja para entrar nos aposentos</div>
      <div className="cargo-net" />
      <div className="barrel b1" />
      <div className="barrel b2" />
      <div className="barrel b3" />
      <div className="crate-decor cd1" />
      <div className="crate-decor cd2" />
      <div className="crate-decor cd3" />
      <div className="sack s1" />
      <div className="sack s2" />
      <div className="hold-map-lantern" />
      <div className="hold-map-glow" />
      {Array.from({ length: Math.min(4, crew) }).map((_, i) => <Npc key={i} i={i + 4} area="hold" />)}
      <Player x={playerX} area="hold" facing={facing} />
    </div>
  </div>;
}

function QuartersScene({ playerX, facing, nearExitDoor, mustSleep, nearBed }: any) {
  return <div className={`quarters-map ${mustSleep ? "night" : ""}`}><div className="quarters-back-wall" /><div className="quarters-floor" /><div className="quarters-window" /><div className="quarters-exit" /><div className="quarters-exit-label" style={{ opacity: nearExitDoor ? 1 : 0 }}>Interaja para sair</div><div className="quarters-bed-big" /><div className="quarters-table-big" /><div className="quarters-chair" /><div className="quarters-lantern" /><div className="quarters-lantern-glow" /><div className="sleep-label" style={{ opacity: mustSleep && nearBed ? 1 : 0 }}>Interaja para dormir</div><Player x={playerX} area="quarters" facing={facing} /></div>;
}

function Player({ x, area, facing }: { x: number; area: Area; facing: Facing }) {
  return <div className={`player ${facing}`} style={{ left: x, bottom: getPlayerY(area) }}><div className="p-hat" /><div className="p-feather" /><div className="p-face" /><div className="p-eye e1" /><div className="p-eye e2" /><div className="p-nose" /><div className="p-beard" /><div className="p-body" /><div className="p-coat" /><div className="p-arm a1" /><div className="p-arm a2" /><div className="p-leg l1" /><div className="p-leg l2" /></div>;
}

function Npc({ i, area = "deck" }: { i: number; area?: Area }) {
  const jobs = ["swab", "carry", "rope", "lookout", "cook", "pace", "crate", "sleepy", "map", "repair", "talk", "guard"];
  const job = jobs[i % jobs.length];
  const positions: Record<string, { x: number; y: number; travel: number }> = { swab: { x: 520, y: 290, travel: 90 }, carry: { x: 720, y: 72, travel: 130 }, rope: { x: 930, y: 290, travel: 20 }, lookout: { x: 1220, y: 290, travel: 0 }, cook: { x: 760, y: 170, travel: 10 }, pace: { x: 1380, y: 290, travel: 160 }, crate: { x: 450, y: 170, travel: 70 }, sleepy: { x: 315, y: 170, travel: 8 }, map: { x: 1545, y: 290, travel: 10 }, repair: { x: 1680, y: 170, travel: 30 }, talk: { x: 1120, y: 290, travel: 45 }, guard: { x: 1880, y: 290, travel: 50 } };
  const base = positions[job];
  const p = { ...base, y: area === "deck" ? 290 : area === "hold" ? 170 : base.y };
  const movingJobs = ["swab", "carry", "pace", "crate", "guard", "talk"];
  const animate = movingJobs.includes(job) ? { left: [p.x, p.x + p.travel, p.x] } : { y: [0, -4, 0] };
  return <motion.div className={`npc npc${i % 3} job-${job}`} initial={{ left: p.x }} animate={animate} transition={{ repeat: Infinity, duration: 2.2 + (i % 4) * 0.55, delay: (i % 5) * 0.18 }} style={{ bottom: p.y }}>
  {/* FIX: prevent floating bug by forcing ground alignment */}<div className="npc-tool" /><div className="n-hair" /><div className="n-head" /><div className="n-eye e1" /><div className="n-eye e2" /><div className="n-body" /><div className="n-arm a1" /><div className="n-arm a2" /><div className="n-leg l1" /><div className="n-leg l2" /></motion.div>;
}

function FullCenter({ children }: { children: React.ReactNode }) { return <div className="min-h-screen bg-slate-950 text-white flex items-center justify-center p-6">{children}</div>; }
function Panel({ title, children }: { title: string; children: React.ReactNode }) { return <FullCenter><Card className="w-full max-w-2xl bg-slate-900 border-slate-700 rounded-2xl shadow-2xl"><CardContent className="p-8 text-center space-y-5"><h1 className="text-3xl font-bold">{title}</h1><div className="space-y-4 text-slate-200">{children}</div></CardContent></Card></FullCenter>; }

function runLogicTests() {
  console.assert(clamp(5, 0, 10) === 5, "clamp keeps values inside range");
  console.assert(clamp(-1, 0, 10) === 0, "clamp applies minimum");
  console.assert(clamp(11, 0, 10) === 10, "clamp applies maximum");
  console.assert(getObjective("cargo").area === "hold", "cargo objective should be in hold");
  console.assert(getObjective("navigate").area === "deck", "navigate objective should be on deck");
  console.assert(getObjective("sleep").area === "quarters", "sleep objective should be in quarters");
  console.assert(getPlayerY("deck") > getPlayerY("hold"), "deck should render above hold");
  console.assert(getCamera(270, "hold", 1280, 720).y === 0, "hold camera should not be vertically offset because it is a separate interior map");
  console.assert(getCamera(1800, "hold", 1280, 720).x > getCamera(270, "hold", 1280, 720).x, "hold camera should follow player horizontally");
  console.assert(getCamera(300, "quarters", 1280, 720).x === 0, "quarters camera should be fixed");
  console.assert(missionsByDay[1].length === 2, "day 1 should have two missions");
  console.assert(getPlayerY("deck") === 290 && getPlayerY("hold") === 170, "deck and hold ground lines should be stable");
